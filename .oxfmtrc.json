{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 80,
  "quoteProps": "consistent",
  "singleQuote": true,
  "trailingComma": "all",
  "semi": false,
  "tabWidth": 2,
  "useTabs": false,
  "arrowParens": "always",
  "ignorePatterns": [
    "**/dist/**",
    "packages/**/_assets/**/assets/**",
    "packages/**/assets/**",
    "**/site/**",
    "website/site/**"
  ]
}
