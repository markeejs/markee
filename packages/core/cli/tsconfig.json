{
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "lib": ["ES2023", "DOM"],
    "outDir": "dist",
    "types": ["node", "@markee/types"]
  },
  "include": ["src"]
}
